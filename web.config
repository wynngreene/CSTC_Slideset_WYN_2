<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <appSettings>
    <!--
      Optional CORS allowlist for secure-data-handler.aspx.
      Leave empty/omit to disable CORS.
      If you set this, use comma-separated origins (scheme + host + optional port).
      Example: https://cstcram1.cos.is.keysight.com,https://some-other-host
    -->
    <add key="SlidesetCorsAllowedOrigins" value="" />

    <!--
      Optional override for where the slideshow state JSON is stored.
      If empty, handler tries ~/App_Data then falls back to system temp.
      You can set an absolute path (e.g. C:\\ProgramData\\CSTC_Slideset\\slideset-data.json)
      or a site-relative path (e.g. App_Data\\slideset-data.json).
    -->
    <add key="SlidesetDataFilePath" value="~/CSTC_Slideset/App_Data/slideset-data.json" />

    <!--
      If true, the handler will NOT fall back to Windows/Temp when App_Data is not writable.
      This prevents silent saves to temp and forces fixing IIS/AppPool permissions.
    -->
    <add key="SlidesetDisableTempFallback" value="false" />
  </appSettings>

  <connectionStrings>
    <!--
      SQL Server connection for persistent slideshow/controller state.
      Update this to match your environment (Integrated Security vs SQL auth, server name, database name).
      Example (Integrated): Server=YOURSQL;Database=CSTC_Slideset;Integrated Security=True;TrustServerCertificate=True;
    -->
    <add name="SlidesetDb" connectionString="Server=YOURSQLSERVER;Database=CSTC_Slideset;Integrated Security=True;TrustServerCertificate=True;" providerName="System.Data.SqlClient" />
  </connectionStrings>

  <system.web>
    <customErrors mode="Off" />
  </system.web>
  
  <!-- Cache Control for Development Testing -->
  <system.webServer>
    <staticContent>
      <clientCache cacheControlMode="DisableCache" />
    </staticContent>
    <httpProtocol>
      <customHeaders>
        <add name="Cache-Control" value="no-cache, no-store, must-revalidate" />
        <add name="Pragma" value="no-cache" />
        <add name="Expires" value="0" />
      </customHeaders>
    </httpProtocol>
  </system.webServer>
</configuration>